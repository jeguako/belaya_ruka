TELEGRAM_BOT_TOKEN=put_your_bot_token_here
ALLOWED_CHAT_ID=
WEBAPP_URL=
AUTO_ACK=false
ENABLE_REMOTE_EXEC=false
CMD_TIMEOUT_SEC=45
EXEC_ALLOWLIST=ls,pwd,cd,du,df,cat,echo,mkdir,mv,cp,rm,python3,pip,git,ps,pkill,kill,open
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional: auto-upload catalog.json to hosting after mini-app sync (curl FTP)
# Same credentials are used by: python3 upload_webapp_ftp.py (index.html, styles.css, script.js, catalog.json)
# Timeweb: FTP password often matches control-panel login for the main account.
FTP_HOST=
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_DIR=
# FTP_TLS: empty or 0 = plain FTP; 1/true = explicit TLS (--ftp-ssl-control); reqd = --ssl-reqd; insecure = TLS + --insecure
FTP_TLS=
